%% PawPal+ final architecture (matches pawpal_system.py)
classDiagram
    direction TB

    class Owner {
        +str name
        +int available_minutes
        +dict preferences
        +list~Pet~ pets
        +register()
        +register_pet(pet)
        +set_available_time(minutes)
        +list_pets()
        +all_tasks() list~Task~
    }

    class Pet {
        +str name
        +str species
        +Owner owner
        +str notes
        +list~Task~ tasks
        +update_profile(**kwargs)
        +add_task(task)
        +remove_task(task)
    }

    class Task {
        +str title
        +str category
        +int duration_minutes
        +int priority
        +Pet pet
        +datetime due
        +str time_str
        +str recurrence
        +str status
        +frequency property
        +mark_complete()
        +mark_pending()
        +time_sort_key()
        +sort_key()
        +instances_for_date(date)
    }

    class Scheduler {
        +tasks_for_owner(owner)
        +sort_by_time(tasks)
        +filter_tasks(tasks, status, pet_name)
        +detect_time_overlaps(tasks, plan_date)
        +collect_tasks_for_day(owner, day)
        +build_daily_plan(owner, tasks, plan_date)
        +detect_conflicts(owner, tasks)
    }

    Owner "1" *-- "0..*" Pet : owns
    Pet "1" *-- "0..*" Task : tasks
    Scheduler ..> Owner : reads budget
    Scheduler ..> Task : plans / filters / overlaps
